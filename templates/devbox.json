{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",

  "packages": [
    "python@3.12",
    "basedpyright@latest",
    "ruff@latest",

    "go@latest",
    "gopls@latest",

    "rustup@latest",

    "nodejs@22",
    "typescript-language-server@latest",
    "biome@latest",

    "jdk@21",
    "jdt-language-server@latest",
    "gradle@latest",
    "maven@latest",

    "yaml-language-server@latest",
    "bash-language-server@latest"
  ],

  "shell": {
    "init_hook": [
      "NU=\"$(command -v nu 2>/dev/null || true)\"",
      "[ -z \"$NU\" ] && [ -x \"$HOME/.local/bin/nu\" ] && NU=\"$HOME/.local/bin/nu\"",
      "if [ -z \"$DEVBOX_NU\" ] && [ -x \"$NU\" ]; then export DEVBOX_NU=1; exec \"$NU\"; fi"
    ],
    "scripts": {
      "fmt": "ruff format . && biome format --write .",
      "lint": "ruff check . && biome lint ."
    }
  }
}
